<% layout('layouts/boilerplate') %>
    <div class="row">
        <h1 class="text-center">New Campground</h1>
        <div class="col-md-6 offset-md-3">

            <form action="/campgrounds" method="POST" class="validated-form" novalidate enctype="multipart/form-data">
                <div class="my-3">
                    <label for="title" class="form-label">Name Campground</label>
                    <!-- ИСПРАВЛЕНО: name="campground[title]" -->
                    <input type="text" name="campground[title]" id="title" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="location" class="form-label">Location Campground</label>
                    <!-- ИСПРАВЛЕНО: name="campground[location]" -->
                    <input type="text" name="campground[location]" id="location" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Image Campground</label>
                    <!-- Картинки оставляем как name="image", их обрабатывает multer -->
                    <input class="form-control" type="file" id="image" name="image" multiple>
                </div>

                <div class="mb-3">
                    <label for="price" class="form-label">Price Campground</label>
                    <div class="input-group">
                        <span class="input-group-text" id="price-label">$</span>
                        <!-- ИСПРАВЛЕНО: name="campground[price]" -->
                        <input type="text" class="form-control" placeholder="0.00" aria-label="Price" id="price"
                            name="campground[price]" aria-describedby="price-label" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description Campground</label>
                    <!-- ИСПРАВЛЕНО: name="campground[description]" (и заодно поправил опечатку в id="description") -->
                    <textarea name="campground[description]" id="description" class="form-control" required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <button class="btn btn-success">Submit</button>
                </div>
            </form>
            <a href="/campgrounds">Cancel</a>
        </div>
    </div>