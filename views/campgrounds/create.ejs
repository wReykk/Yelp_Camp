<% layout('layouts/boilerplate') %>
    <div class="row">
        <h1 class="text-center">New Campground</h1>
        <div class="col-6 offset-3">

            <form action="/campgrounds" method="POST" class="validated-form" novalidate>
                <div class="my-3">
                    <label for="title" class="form-label">Name Campground</label>
                    <input type="text" name="title" id="title" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="title" class="form-label">Location Campground</label>
                    <input type="text" name="location" id="location" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <!-- <div class="mb-3">
                    <label for="formFile" class="form-label">Image Campground</label>
                    <input class="form-control" type="file" id="formFile">
                </div> -->
                <div class="mb-3">
                    <label for="title" class="form-label">Image Campground</label>
                    <input type="text" name="image" id="image" class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label for="price" class="form-label">Price Campground</label>
                    <div class="input-group">
                        <span class="input-group-text" id="price-label">$</span>
                        <input type="text" class="form-control" placeholder="0.00" aria-label="Username" id="price"
                            name="price" aria-describedby="price-label" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>

                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description Campground</label>
                    <textarea type="text" name="description" id="descfription" class="form-control" required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <button class="btn btn-success">Submit</button>
                </div>
            </form>
            <a href="/campgrounds">Cancel</a>
        </div>
    </div>